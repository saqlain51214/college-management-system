# ── Production .env for shared cPanel hosting (e.g. HosterPK) — NO Redis ──
# Copy this to .env on the server and fill in the real values. Never commit
# the real .env to git.

APP_NAME="Jinnah Degree College Astore"
APP_ENV=production
APP_KEY=                    # generate on server: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://jinnahdegreecollegeastore.com
APP_FORCE_HTTPS=true

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning
LOG_DAILY_DAYS=14

# ── Database (create via cPanel → MySQL Databases; cPanel prefixes both the
#    DB name and the DB user with your cPanel username, e.g. jinnade_jdca) ──
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=jinnade_jdca
DB_USERNAME=jinnade_jdcauser
DB_PASSWORD=CHANGE_ME

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public

# No Redis on shared hosting — use these instead:
QUEUE_CONNECTION=sync
CACHE_STORE=database
CACHE_PREFIX=jdca-production

SECURITY_HEADERS_ENABLED=true
SECURITY_CSP_ENABLED=false
SECURITY_CSP=

RATE_LIMIT_CONTACT_PER_MINUTE=5
RATE_LIMIT_ADMISSIONS_PER_MINUTE=40
RATE_LIMIT_STUDENT_LOGIN_PER_MINUTE=5
RATE_LIMIT_TEACHER_LOGIN_PER_MINUTE=5
RATE_LIMIT_FEE_CHALLAN_PER_MINUTE=10

# ── Email — create the mailbox first in cPanel → Email Accounts, then use
#    its own SMTP settings here (from your hosting welcome email) ──
MAIL_MAILER=smtp
MAIL_HOST=mail.jinnahdegreecollegeastore.com
MAIL_PORT=465
MAIL_SCHEME=ssl
MAIL_USERNAME=noreply@jinnahdegreecollegeastore.com
MAIL_PASSWORD=CHANGE_ME
MAIL_FROM_ADDRESS=noreply@jinnahdegreecollegeastore.com
MAIL_FROM_NAME="${APP_NAME}"
CONTACT_NOTIFICATION_EMAIL=info@jinnahdegreecollegeastore.com
ADMISSIONS_NOTIFICATION_EMAIL=admissions@jinnahdegreecollegeastore.com
STUDENT_SUPPORT_EMAIL=support@jinnahdegreecollegeastore.com
SEND_STUDENT_WELCOME_EMAIL=true

VITE_APP_NAME="${APP_NAME}"
